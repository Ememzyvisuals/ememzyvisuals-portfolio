# ─────────────────────────────────────────────────────────────────────────────
# EMMZYVISUALS — ENVIRONMENT VARIABLES
# Copy this file to .env.local for local dev
# Add ALL of these in Vercel Dashboard → Your Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── YOUR SITE URL ─────────────────────────────────────────────────────────────
# During development: http://localhost:3000
# After Vercel deploy: https://emmzyvisuals.vercel.app  (or your custom domain)
# Change this once Vercel gives you your deployment URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── DATABASE (Neon — free PostgreSQL with pgvector) ───────────────────────────
# Instructions: see DEPLOY_GUIDE.md Step 1
DATABASE_URL=
DIRECT_URL=

# ── AI (Groq — free) ──────────────────────────────────────────────────────────
# Instructions: see DEPLOY_GUIDE.md Step 2
GROQ_API_KEY=

# ── EMAIL (Resend — free, 3000 emails/month) ──────────────────────────────────
# Instructions: see DEPLOY_GUIDE.md Step 3
RESEND_API_KEY=
CONTACT_EMAIL=contact@ememzyvisuals.com

# ── ADMIN PANEL ───────────────────────────────────────────────────────────────
# This is the key you use to access /admin?key=YOUR_KEY
# Make it something only you know. No spaces.
NEXT_PUBLIC_ADMIN_KEY=emmzy2025

# ── GOOGLE SEARCH CONSOLE VERIFICATION ───────────────────────────────────────
# Add this in Vercel → Settings → Environment Variables
# Get the value from search.google.com/search-console
# Choose "HTML tag" → copy ONLY the content value (the part inside content="...")
# Example: if Google gives you <meta name="google-site-verification" content="AbCdEf123" />
# Then paste just:  AbCdEf123
GOOGLE_SITE_VERIFICATION=

# ── CLOUDINARY (free image hosting for gallery) ───────────────────────────────
# Sign up free at cloudinary.com — 25GB free storage
# These are NOT secret — the admin page stores them in browser localStorage
# You don't need to add these to Vercel — they're saved in your browser only
# CLOUDINARY_CLOUD_NAME is your cloud name from the Cloudinary dashboard
# Your upload preset must be set to "Unsigned" in Cloudinary settings
